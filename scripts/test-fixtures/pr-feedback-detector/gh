#!/usr/bin/env bash
set -euo pipefail

scenario="${PR_FEEDBACK_FIXTURE_SCENARIO:-no_action}"
command_name="${1:-}"
subcommand="${2:-}"

if [ "$command_name" = "repo" ] && [ "$subcommand" = "view" ]; then
    printf '%s\n' '{"nameWithOwner":"fixture/repo"}'
    exit 0
fi

if [ "$command_name" = "pr" ] && [ "$subcommand" = "list" ]; then
    if [ "$scenario" = "malformed" ]; then
        printf '%s\n' '{not-json'
        exit 0
    fi
    if [ "$scenario" = "invalid_shape" ]; then
        printf '%s\n' '{}'
        exit 0
    fi
    if [ "$scenario" = "pr_review" ] || [ "$scenario" = "ci_failure" ] || [ "$scenario" = "ci_error" ] || [ "$scenario" = "ci_optional" ] || [ "$scenario" = "ci_status_matrix" ] || [ "$scenario" = "diff_over_limit" ] || [ "$scenario" = "required_checks_unavailable" ] || [ "$scenario" = "invalid_pr_shape" ] || [ "$scenario" = "invalid_required_shape" ] || [ "$scenario" = "issue_priority" ]; then
        printf '%s\n' '[{"number":7}]'
    else
        printf '%s\n' '[]'
    fi
    exit 0
fi

if [ "$command_name" = "pr" ] && [ "$subcommand" = "view" ]; then
    if [ "$scenario" = "pr_review" ]; then
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","baseRefName":"main","headRefOid":"abc123","reviewDecision":"CHANGES_REQUESTED","additions":10,"deletions":2,"changedFiles":2,"statusCheckRollup":[]}'
    elif [ "$scenario" = "ci_error" ]; then
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","baseRefName":"main","headRefOid":"abc123","reviewDecision":"","additions":10,"deletions":2,"changedFiles":2,"statusCheckRollup":[{"context":"backend","state":"ERROR","detailsUrl":"https://example.test/check/7"}]}'
    elif [ "$scenario" = "ci_optional" ]; then
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","headRefOid":"abc123","baseRefName":"main","reviewDecision":"","additions":10,"deletions":2,"changedFiles":2,"statusCheckRollup":[{"name":"optional","conclusion":"FAILURE","detailsUrl":"https://example.test/check/optional"}]}'
    elif [ "$scenario" = "diff_over_limit" ]; then
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","baseRefName":"main","headRefOid":"abc123","reviewDecision":"","additions":1001,"deletions":0,"changedFiles":2,"statusCheckRollup":[]}'
    elif [ "$scenario" = "ci_status_matrix" ]; then
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","baseRefName":"main","headRefOid":"abc123","reviewDecision":"","additions":10,"deletions":2,"changedFiles":2,"statusCheckRollup":[{"name":"failure","conclusion":"FAILURE","detailsUrl":"https://example.test/check/failure"},{"name":"error","conclusion":"ERROR","detailsUrl":"https://example.test/check/error"},{"name":"cancelled","conclusion":"CANCELLED","detailsUrl":"https://example.test/check/cancelled"},{"name":"timed-out","conclusion":"TIMED_OUT","detailsUrl":"https://example.test/check/timed-out"},{"name":"action-required","conclusion":"ACTION_REQUIRED","detailsUrl":"https://example.test/check/action-required"},{"name":"startup-failure","conclusion":"STARTUP_FAILURE","detailsUrl":"https://example.test/check/startup-failure"}]}'
    elif [ "$scenario" = "invalid_pr_shape" ]; then
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","baseRefName":"main","headRefOid":"abc123","reviewDecision":"","additions":10,"deletions":2,"changedFiles":2}'
    else
        printf '%s\n' '{"number":7,"title":"T2","url":"https://example.test/pr/7","state":"OPEN","headRefName":"codex/example","baseRefName":"main","headRefOid":"abc123","reviewDecision":"","additions":10,"deletions":2,"changedFiles":2,"statusCheckRollup":[{"name":"backend","conclusion":"FAILURE","detailsUrl":"https://example.test/check/7"}]}'
    fi
    exit 0
fi

if [ "$command_name" = "api" ]; then
    if [ "$scenario" = "required_checks_unavailable" ] || [ "$scenario" = "issue_priority" ]; then
        printf 'branch protection unavailable\n' >&2
        exit 1
    fi
    if [ "$scenario" = "invalid_required_shape" ]; then
        printf '%s\n' '{}'
        exit 0
    fi
    if [ "$scenario" = "ci_status_matrix" ]; then
        printf '%s\n' '{"contexts":["failure","error","cancelled","timed-out","action-required","startup-failure"],"checks":[]}'
        exit 0
    fi
    printf '%s\n' '{"contexts":["backend"],"checks":[{"context":"backend","app_id":15368}]}'
    exit 0
fi

if [ "$command_name" = "issue" ] && [ "$subcommand" = "list" ]; then
    if [ "$scenario" = "issue_rejection" ] || [ "$scenario" = "issue_priority" ]; then
        printf '%s\n' '[{"number":110,"title":"리뷰 반려: codex/example","url":"https://example.test/issues/110","updatedAt":"2026-07-19T00:00:00Z"}]'
    else
        printf '%s\n' '[]'
    fi
    exit 0
fi

if [ "$command_name" = "issue" ] && [ "$subcommand" = "view" ]; then
    printf '%s\n' '{"number":110,"title":"리뷰 반려: codex/example","url":"https://example.test/issues/110","updatedAt":"2026-07-19T00:00:00Z","body":"diff over limit: split request","comments":[]}'
    exit 0
fi

printf 'unexpected fixture command: %s %s\n' "$command_name" "$subcommand" >&2
exit 1
